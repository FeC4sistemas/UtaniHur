# URLs de imagens/links externos (opcional — os padrões apontam para o RubinOT).
# Placeholders disponíveis: {type} {addons} {head} {body} {legs} {feet} {id}

# Gerador de imagem de outfit
# VITE_OUTFIT_URL=https://outfits.rubinot.com.br/animoutfit.php?id={type}&addons={addons}&head={head}&body={body}&legs={legs}&feet={feet}&mount=0&direction=3

# Imagem de item pelo clientId
# VITE_ITEM_URL=https://static.rubinot.com.br/images/items/{id}.png

# Link do leilão no site oficial
# VITE_AUCTION_URL=https://rubinot.com.br/bazaar?auction={id}
