# URLs de imagens/links externos (opcional — os padrões apontam para o RubinOT).
# Placeholders disponíveis: {type} {addons} {head} {body} {legs} {feet} {id}

# Fallback remoto para imagem de outfit (usado quando não há sprite local)
# VITE_OUTFIT_URL=https://static.tibia.com/images/charactertrade/outfits/{type}_{addons}.gif

# Fallback remoto para imagem de item pelo clientId
# VITE_ITEM_URL=https://static.tibia.com/images/charactertrade/objects/{id}.gif

# Link do leilão no site oficial
# VITE_AUCTION_URL=https://rubinot.com.br/bazaar?auction={id}
